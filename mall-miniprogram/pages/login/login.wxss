.login-container {
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  box-sizing: border-box;
}

.login-header {
  height: 600rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 40rpx;
  justify-content: flex-end;
}

.logo {
  width: 150rpx;
  height: 150rpx;
  margin-bottom: 30rpx;
}

.title {
  font-size: 36rpx;
  color: rgb(17, 16, 16);
  font-weight: bold;
  text-align: center;
}

.login-tip {
  text-align: center;
  color: #666;
  font-size: 28rpx;
  margin: 40rpx 0;
}

.userinfo-title {
  font-size: 28rpx;
  color: rgba(0, 0, 0, 0.993);
  text-align: center;
  font-weight: bold;
}

.button-group {
  margin: 60rpx 0;
}

.agreement {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #999;
  margin-top: 40rpx;
}

.agreement .checkbox {
  transform: scale(0.8);
  margin-right: 10rpx;
}

.link {
  color: #1989fa;
}

  /* 用户信息 */
  .userinfo {
      display: flex;
      flex-direction: column;
      gap: 30rpx;
  }
  .userinfo.title {
      align-self: center;
      font-size: 28rpx;
      color: #999;
      font-weight: lighter;
  }
  .userinfo .avatar {
      align-self: center;
      width: 200rpx;
      height: 200rpx;
      border-radius: 50%;
      background-color: #b0b0b0;
  }
/* pages/search/search.wxss */
.page-container {
    width: 100vw;
    height: 100vh;
    background-color: #f1f3f5;
    padding: 20rpx; 
    box-sizing: border-box;
  }
  
  /* 整体搜索框容器 */
  .van-search {
    border: 1px solid red !important; /* 红色边框 */
    border-radius: 30rpx !important; /* 增大圆角 */
    padding: 5rpx 0 !important; /* 减小上下内边距 */
    background-color: #fff !important; /* 背景色与搜索区域统一 */
  }
  
  /* 搜索输入区域 */
  .van-search__content {
    margin: 0 5rpx !important; /* 减小左右边距 */
    border-radius: 25rpx !important; /* 输入框圆角略小于整体 */
    background-color: #f1f3f5 !important; /* 保持原有背景色 */
  }
  
  /* 搜索按钮容器 */
  .van-search__action {
    padding-right: 5rpx !important; /* 减小右侧内边距 */
  }
  
  /* 搜索按钮 */
  .search-btn {
    margin: 0 10rpx !important; /* 减小按钮左右边距 */
    background-color: red;
    color: white;
    padding: 8rpx 15rpx !important; /* 调整按钮内边距 */
    border-radius: 20rpx !important; /* 按钮圆角 */
    white-space: nowrap !important; /* 防止文字换行 */
  }
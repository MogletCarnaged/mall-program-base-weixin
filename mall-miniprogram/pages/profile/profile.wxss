.page-container {
  height: 100vh;
  width: 100vw;
  display: flex;
  flex-direction: column;
  background-color: #E6F3FF;
  overflow: hidden;
}

.profile {
  height: 400rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center
}
.image {
  height: 215rpx;
  width: 215rpx;
}

.details {
  flex-grow: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.details-list {
  width: 80%;
  padding: 20rpx;
  background-color: #FFF;
  border-radius: 10%;
  border-radius: 40rpx;
  margin-bottom: 40rpx;
}

.service-list {
  display: grid;
  grid-template-columns: repeat(5,1fr);
}

.service {
  display: flex;
  flex-direction: column;
  justify-content: space-evenly;
  align-items: center;
}

.service-title {
  font-weight: bold;
  margin-bottom: 20rpx;
}

.service>image {
  width: 88rpx;
  height: 88rpx;
}
.service>text {
  font-size: 22rpx;
  height: 60rpx;
  text-align: center;
}